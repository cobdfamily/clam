# fastlane lanes for a GENERATED app. Run AFTER `gen.mjs <app>` has produced
# .generated/<app>/ios. Pass the app id via the `app` option.
#
#   fastlane ios release app:ca.cobd.app.alpha
#
# Signing is installed by `match` and applied via exportOptions.plist — it does
# not depend on anything stored in the regenerated Xcode project.

platform :ios do
  desc "Build + sign + upload a generated app"
  lane :release do |options|
    app_id = options[:app] || UI.user_error!("pass app:<bundle-id>")

    match(type: "appstore", app_identifier: app_id, readonly: true)

    build_app(
      project: ".generated/#{app_id}/ios/App/App.xcodeproj",
      scheme: "App",
      export_method: "app-store",
      export_options: "templates/exportOptions.plist"
    )

    upload_to_testflight(skip_waiting_for_build_processing: true)
  end
end
