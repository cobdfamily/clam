{
  "name": "@cobdfamily/cobdcorekit",
  "version": "0.1.0",
  "description": "COBDCoreKit: the single client API that runs in the page (the top-level Capacitor WebView) and calls the Capacitor plugins directly — torch, geolocation (navigator shim), in-app browser, nav, pdf — plus the capability→native-permission map. No iframe, no host bridge. Replaces the former cobdcorekit + cobdhostkit split.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/cobdfamily/clam.git",
    "directory": "packages/cobdcorekit"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./permissions": {
      "types": "./dist/permissions.d.ts",
      "default": "./dist/permissions.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "AGPL-3.0",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc",
    "test": "node --test --import tsx test/*.test.ts",
    "prepublishOnly": "npm run clean && npm run build && npm test"
  },
  "dependencies": {
    "@capacitor/browser": "^8.0.3",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/haptics": "^8.0.2",
    "@capgo/capacitor-flash": "^8.0.28"
  },
  "peerDependencies": {
    "@capacitor/core": "^8.0.0"
  },
  "devDependencies": {
    "@capacitor/core": "^8.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.6.3"
  }
}
