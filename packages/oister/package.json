{
  "name": "@cobdfamily/oister",
  "version": "0.0.0",
  "private": true,
  "description": "The oister umbrella-shell index.html as a Handlebars template plus a TypeScript generator: renderOisterShell(oister.json) -> a ready-to-drop-in page. Consumed by @cobdfamily/cobd-app-generator when assembling each app's webDir.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./template": "./dist/assets/index.html"
  },
  "files": [
    "dist"
  ],
  "license": "AGPL-3.0",
  "scripts": {
    "build": "tsc && node build/copy-assets.mjs",
    "test": "node --test --import tsx test/*.test.ts"
  },
  "dependencies": {
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.20.5",
    "typescript": "^5.6.3"
  }
}
